# quit on non-interactive
case $- in
*i*) ;;
*) return ;;
esac

# ==== prompt theme ====

# this is required because lower versions of bash (e.g. 3.2 on macos) don't support `\w`
function prompt_path() {
  local dir="$PWD"
  if [[ "$dir" == "$HOME"* ]]; then
    dir="~${dir#$HOME}"
  fi
  local parts=(${dir//\// })
  local count=${#parts[@]}
  if ((count > 2)); then
    echo "~/.../${parts[${#parts[@]} - 1]}"
  else
    echo "$dir"
  fi
}

function prompt() {
  if [ $? -eq 0 ]; then
    PS1="\[\e[37m\][\[\e[93m\]\h\[\e[0m\]\[\e[37m\]:\[\e[94m\]\$(prompt_path)\[\e[0m\]\[\e[37m\]] \[\e[92m\]$\[\e[0m\] "
  else
    PS1="\[\e[37m\][\[\e[93m\]\h\[\e[0m\]\[\e[37m\]:\[\e[94m\]\$(prompt_path)\[\e[0m\]\[\e[37m\]] \[\e[31m\]$\[\e[0m\] "
  fi
}

PROMPT_DIRTRIM=1
PROMPT_COMMAND=prompt

# ==== history ====
HISTCONTROL=ignoreboth
shopt -s histappend
HISTSIZE=1000
HISTFILESIZE=2000

# ==== completions ====
if ! shopt -oq posix; then # Enable bash completion if available
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

bind "set completion-ignore-case on"     # case insensitive
bind "set completion-map-case on"        # hyphen == underscore
bind "set show-all-if-ambiguous on"      # show completions immediately
bind "set mark-directories on"           # add trailing / to dirs
bind "set mark-symlinked-directories on" # add trailing / to dirs
bind "set colored-stats on"              # colorize

# ==== aliases ====
alias config='vim ~/.bashrc'
alias reload='clear && exec bash'
alias ls='ls -A --color=auto'
alias sizeof="du -hs"
alias cls="clear; ls"
alias c="clear"
alias e="vim"
alias '?'='echo $?'
alias less='less -R'
alias rm='rm -I'
alias diff='diff -u'

# ==== grep aliases ====
alias grep='grep -ni --color=auto --exclude-dir={.bzr,cvs,.git,.hg,.svn,.idea,.tox,.venv,venv}'
alias grepa='grep -Rni --exclude-dir={.bzr,cvs,.git,.hg,.svn,.idea,.tox,.venv,venv}'
alias grepf='find . | \grep -i --color=always'
alias grepd='find . -type d | rg -iu'

# ==== git aliases ====
alias gst='git status'
alias gl='git pull'
alias gp='git push'
alias gf='git fetch'
alias gc='git commit --verbose'
alias gcm='git commit -m'
alias gca='git commit --verbose --all'
alias ga='git add'
alias grmc='git rm --cached'
alias gbs='git switch'
alias gb='git branch'

# ==== colorize man pages ====
export LESS_TERMCAP_mb=$'\e[1;36m'
export LESS_TERMCAP_md=$'\e[1;33m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_so=$'\e[1;44;33m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;32m'
export LESS_TERMCAP_ue=$'\e[0m'
export LESS_TERMCAP_mh=$'\e[0m'
export LESS_TERMCAP_mr=$'\e[7m'
export LESS_TERMCAP_ZJ=$'\e[1;35m'
export LESS_TERMCAP_ZN=$'\e[0m'

# ==== git and diff colors ====
export CLICOLOR=1
if command -v git &>/dev/null; then
  git config --global color.ui auto
  git config --global color.status auto
  git config --global color.diff auto
  git config --global color.branch auto
fi

# ==== env variables ====
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"

# ==== brew ====
if [ -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ==== umask ====
umask 002

# ==== no bells ====
bind 'set bell-style none'
