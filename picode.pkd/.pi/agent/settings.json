{
  "defaultProvider": "synthetic",
  "defaultModel": "hf:zai-org/GLM-5.1",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": true,
  "theme": "catppuccin-mocha",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "compact-footer": {
    "order": ["pwd", "context", "cost", "<flex>", "model", "statuses"],
    "separator": " │ ",
    "priority": {
      "pwd": 1,
      "cost": 2,
      "statuses": 3,
      "model": 4,
      "context": 5
    },
    "collapse": {
      "pwd": { "short": 100, "minimal": 60 },
      "context": { "short": 70 },
      "statuses": { "short": 90 }
    }
  },
  "synthetic": {
    "hideStatuses": {
      "search": true
    }
  },
  "lastChangelogVersion": "0.74.0",
  "packages": []
}
