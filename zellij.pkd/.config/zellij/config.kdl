
// Global Settings

default_shell "nu"
theme "catppuccin-mocha"
welcome_screen false
show_startup_tips false
show_release_notes false

default_layout "default"
pane_frames false
simplified_ui true
scroll_buffer_size 50000
copy_command "pbcopy"
osc8_hyperlinks true
mouse_click_through true

// Keybinds

keybinds clear-defaults=true {
    // ═══════════════════════════════════════════════════════════
    // MODES — sticky (no auto-return), bare keys, Esc exits
    // Flow: normal → Ctrl+Space → tmux (hub) → single key → sub-modes
    // Esc:  sub-modes → tmux, tmux → normal
    // Ctrl+c: any mode → normal (hard abort)
    // ═══════════════════════════════════════════════════════════

    locked {
        bind "Ctrl g" { SwitchToMode "normal"; }
    }

    // ── tmux: landing pad / command hub ──────────────────────
    tmux {
        // navigation
        bind "h" { MoveFocus "left"; }
        bind "j" { MoveFocus "down"; }
        bind "k" { MoveFocus "up"; }
        bind "l" { MoveFocus "right"; }
        bind "[" { GoToPreviousTab; }
        bind "]" { GoToNextTab; }
        bind "1" { GoToTab 1; SwitchToMode "normal"; }
        bind "2" { GoToTab 2; SwitchToMode "normal"; }
        bind "3" { GoToTab 3; SwitchToMode "normal"; }
        bind "4" { GoToTab 4; SwitchToMode "normal"; }
        bind "5" { GoToTab 5; SwitchToMode "normal"; }
        bind "6" { GoToTab 6; SwitchToMode "normal"; }
        bind "7" { GoToTab 7; SwitchToMode "normal"; }
        bind "8" { GoToTab 8; SwitchToMode "normal"; }
        bind "9" { GoToTab 9; SwitchToMode "normal"; }
        // common operations
        bind "n" { NewPane; }
        bind "N" { NewTab; SwitchToMode "normal"; }
        bind "x" { CloseFocus; }
        bind "f" { ToggleFocusFullscreen; }
        bind "w" { ToggleFloatingPanes; SwitchToMode "normal"; }
        bind "b" { BreakPane; }
        bind "d" { Detach; }
        bind "q" { Quit; }
        // mode dispatch
        bind "p" { SwitchToMode "pane"; }
        bind "t" { SwitchToMode "tab"; }
        bind "r" { SwitchToMode "resize"; }
        bind "m" { SwitchToMode "move"; }
        bind "s" { SwitchToMode "scroll"; }
        bind "S" { SwitchToMode "session"; }
        // exit / lock
        bind "esc" { SwitchToMode "normal"; }
        bind "Ctrl g" { SwitchToMode "locked"; }
    }

    // ── pane: pane management ────────────────────────────────
    pane {
        bind "h" { MoveFocus "left"; }
        bind "j" { MoveFocus "down"; }
        bind "k" { MoveFocus "up"; }
        bind "l" { MoveFocus "right"; }
        bind "n" { NewPane; }
        bind "d" { NewPane "down"; }
        bind "r" { NewPane "right"; }
        bind "s" { NewPane "stacked"; }
        bind "f" { ToggleFocusFullscreen; }
        bind "z" { TogglePaneFrames; }
        bind "e" { TogglePaneEmbedOrFloating; }
        bind "i" { TogglePanePinned; }
        bind "w" { ToggleFloatingPanes; }
        bind "p" { SwitchFocus; }
        bind "x" { CloseFocus; }
        bind "c" { SwitchToMode "renamepane"; PaneNameInput 0; }
        bind "o" { FocusNextPane; }
        bind "space" { NextSwapLayout; }
        bind "[" { PreviousSwapLayout; }
        bind "]" { NextSwapLayout; }
    }

    // ── tab: tab management ──────────────────────────────────
    tab {
        bind "h" { GoToPreviousTab; }
        bind "k" { GoToPreviousTab; }
        bind "j" { GoToNextTab; }
        bind "l" { GoToNextTab; }
        bind "n" { NewTab; }
        bind "r" { SwitchToMode "renametab"; TabNameInput 0; }
        // bind "s" { ToggleActiveSyncTab; }
        bind "x" { CloseTab; }
        bind "b" { BreakPane; }
        bind "[" { BreakPaneLeft; }
        bind "]" { BreakPaneRight; }
        bind "tab" { ToggleTab; }
        bind "i" { MoveTab "left"; }
        bind "o" { MoveTab "right"; }
    }

    // ── resize: pane resizing ────────────────────────────────
    // Note: arrow keys retained here; future consideration for removal
    resize {
        bind "h" { Resize "Increase left"; }
        bind "j" { Resize "Increase down"; }
        bind "k" { Resize "Increase up"; }
        bind "l" { Resize "Increase right"; }
        bind "left" { Resize "Increase left"; }
        bind "down" { Resize "Increase down"; }
        bind "up" { Resize "Increase up"; }
        bind "right" { Resize "Increase right"; }
        bind "H" { Resize "Decrease left"; }
        bind "J" { Resize "Decrease down"; }
        bind "K" { Resize "Decrease up"; }
        bind "L" { Resize "Decrease right"; }
        bind "+" { Resize "Increase"; }
        bind "-" { Resize "Decrease"; }
        bind "=" { Resize "Increase"; }
    }

    // ── move: pane repositioning ─────────────────────────────
    move {
        bind "h" { MovePane "left"; }
        bind "j" { MovePane "down"; }
        bind "k" { MovePane "up"; }
        bind "l" { MovePane "right"; }
        bind "n" { MovePane; }
        bind "p" { MovePaneBackwards; }
        bind "tab" { MovePane; }
    }

    // ── scroll: scrollback navigation ───────────────────────
    scroll {
        bind "e" { EditScrollback; SwitchToMode "normal"; }
        bind "/" { SwitchToMode "entersearch"; SearchInput 0; }
    }

    // ── search: search within scrollback ─────────────────────
    search {
        bind "c" { SearchToggleOption "CaseSensitivity"; }
        bind "n" { Search "down"; }
        bind "o" { SearchToggleOption "WholeWord"; }
        bind "p" { Search "up"; }
        bind "w" { SearchToggleOption "Wrap"; }
    }

    // ── session: session management ──────────────────────────
    session {
        bind "a" {
            LaunchOrFocusPlugin "zellij:about" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "c" {
            LaunchOrFocusPlugin "configuration" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "l" {
            LaunchOrFocusPlugin "zellij:layout-manager" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "p" {
            LaunchOrFocusPlugin "plugin-manager" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "s" {
            LaunchOrFocusPlugin "zellij:share" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "w" {
            LaunchOrFocusPlugin "session-manager" {
                floating true
                move_to_focused_tab true
            }
        }
    }

    // ═══════════════════════════════════════════════════════════
    // INPUT SUB-MODES — Esc/Enter return to parent mode
    // ═══════════════════════════════════════════════════════════

    entersearch {
        bind "Ctrl c" { SwitchToMode "normal"; }
        bind "esc" { SwitchToMode "scroll"; }
        bind "enter" { SwitchToMode "search"; }
    }

    renametab {
        bind "enter" { SwitchToMode "tab"; }
        bind "esc" { UndoRenameTab; SwitchToMode "tab"; }
        bind "Ctrl c" { UndoRenameTab; SwitchToMode "normal"; }
    }

    renamepane {
        bind "enter" { SwitchToMode "pane"; }
        bind "esc" { UndoRenamePane; SwitchToMode "pane"; }
        bind "Ctrl c" { UndoRenamePane; SwitchToMode "normal"; }
    }

    // ═══════════════════════════════════════════════════════════
    // SHARED BINDS
    // ═══════════════════════════════════════════════════════════

    // normal mode: Alt binds (pass-through, only Alt keys intercepted)
    shared_except "locked" {
        // entry to hub
        bind "Ctrl Space" { SwitchToMode "tmux"; }
        // pane navigation
        bind "Alt h" { MoveFocusOrTab "left"; }
        bind "Alt j" { MoveFocus "down"; }
        bind "Alt k" { MoveFocus "up"; }
        bind "Alt l" { MoveFocusOrTab "right"; }
        bind "Alt left" { MoveFocusOrTab "left"; }
        bind "Alt down" { MoveFocus "down"; }
        bind "Alt up" { MoveFocus "up"; }
        bind "Alt right" { MoveFocusOrTab "right"; }
        // tab navigation
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
        bind "Alt [" { GoToPreviousTab; }
        bind "Alt ]" { GoToNextTab; }
        // quick ops
        bind "Alt n" { NewPane; }
        bind "Alt f" { ToggleFloatingPanes; }
        bind "Alt p" { TogglePaneInGroup; }
        bind "Alt Shift p" { ToggleGroupMarking; }
        bind "Alt q" { Quit; }
        bind "Alt d" { Detach; }
        bind "Alt +" { Resize "Increase"; }
        bind "Alt -" { Resize "Decrease"; }
        bind "Alt =" { Resize "Increase"; }
        // lock
        bind "Ctrl g" { SwitchToMode "locked"; }
    }

    // Ctrl+c: universal hard abort → normal (from any mode)
    shared_except "normal" "locked" {
        bind "Ctrl c" { SwitchToMode "normal"; }
    }

    // Esc: soft exit → tmux hub (from any primary sub-mode)
    shared_among "pane" "tab" "resize" "move" "scroll" "search" "session" {
        bind "esc" { SwitchToMode "tmux"; }
    }

    // scroll/search shared navigation
    shared_among "scroll" "search" {
        bind "PageDown" { PageScrollDown; }
        bind "PageUp" { PageScrollUp; }
        bind "j" { HalfPageScrollDown; }
        bind "k" { HalfPageScrollUp; }
        bind "J" { PageScrollDown; }
        bind "K" { PageScrollUp; }
        bind "g" { ScrollToTop; }
        bind "G" { ScrollToBottom; }
        // Ctrl+c override: scroll to bottom then abort to normal
        bind "Ctrl c" { ScrollToBottom; SwitchToMode "normal"; }
    }
}

// Plugin aliases - can be used to change the implementation of Zellij
// changing these requires a restart to take effect
plugins {
    about location="zellij:about"
    configuration location="zellij:configuration"
    plugin-manager location="zellij:plugin-manager"
    session-manager location="zellij:session-manager"
}

// Plugins to load in the background when a new session starts
// eg. "file:/path/to/my-plugin.wasm"
// eg. "https://example.com/my-plugin.wasm"
load_plugins {
    zellij:link
    "https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm"
}
