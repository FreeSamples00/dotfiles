
// Global Settings

default_shell "nu"
theme "catppuccin-mocha"
welcome_screen false
show_startup_tips false
show_release_notes false

default_layout "default"
pane_frames false
simplified_ui true
scroll_buffer_size 50000
osc8_hyperlinks true
mouse_click_through true

// Keybinds

keybinds clear-defaults=true {
    // ═══════════════════════════════════════════════════════════
    // MODES — sticky (no auto-return), bare keys, Esc exits
    // Flow: normal → Alt Space → tmux (hub) → single key → sub-modes
    // Esc:  sub-modes → tmux, tmux → normal
    // Ctrl+c: any mode → normal (hard abort)
    // ═══════════════════════════════════════════════════════════

    locked {
        bind "Alt g" { SwitchToMode "normal"; }
    }

    // ── tmux: landing pad / command hub (sticky) ─────────────
    tmux {
        // pane navigation
        bind "j" { MoveFocus "left"; }
        bind "k" { MoveFocus "right"; }
        // tab navigation
        bind "J" { GoToNextTab; }
        bind "K" { GoToPreviousTab; }
        bind "1" { GoToTab 1; }
        bind "2" { GoToTab 2; }
        bind "3" { GoToTab 3; }
        bind "4" { GoToTab 4; }
        bind "5" { GoToTab 5; }
        bind "6" { GoToTab 6; }
        bind "7" { GoToTab 7; }
        bind "8" { GoToTab 8; }
        bind "9" { GoToTab 9; }
        // tab + pane ops
        bind "n" { NewTab; }
        bind "|" { NewPane "right"; }
        bind "x" { CloseFocus; }
        bind "w" { ToggleFloatingPanes; }
        // session
        bind "d" { Detach; }
        bind "Q" { Quit; }
        // mode dispatch
        bind "r" { SwitchToMode "renametab"; TabNameInput 0; }
        bind "s" { SwitchToMode "scroll"; }
        // exit / lock
        bind "esc" { SwitchToMode "normal"; }
        bind "Alt g" { SwitchToMode "locked"; }
    }

    // ── scroll: scrollback navigation ───────────────────────
    scroll {
        bind "e" { EditScrollback; SwitchToMode "normal"; }
        bind "PageDown" { PageScrollDown; }
        bind "PageUp" { PageScrollUp; }
        bind "j" { HalfPageScrollDown; }
        bind "k" { HalfPageScrollUp; }
        bind "J" { PageScrollDown; }
        bind "K" { PageScrollUp; }
        bind "g" { ScrollToTop; }
        bind "G" { ScrollToBottom; }
        // Ctrl+c override: scroll to bottom then abort to normal
        bind "Ctrl c" { ScrollToBottom; SwitchToMode "normal"; }
    }

    // ═══════════════════════════════════════════════════════════
    // INPUT SUB-MODES — Esc/Enter return to parent mode
    // ═══════════════════════════════════════════════════════════

    renametab {
        bind "enter" { SwitchToMode "tmux"; }
        bind "esc" { UndoRenameTab; SwitchToMode "tmux"; }
        bind "Ctrl c" { UndoRenameTab; SwitchToMode "normal"; }
    }

    // ═══════════════════════════════════════════════════════════
    // SHARED BINDS
    // ═══════════════════════════════════════════════════════════

    // normal mode: Alt binds (pass-through, only Alt keys intercepted)
    shared_except "locked" {
        // entry to hub
        bind "Alt Space" { SwitchToMode "tmux"; }
        // tab navigation
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
        // lock
        bind "Alt g" { SwitchToMode "locked"; }
    }

    // Ctrl+c: universal hard abort → normal (from any mode)
    shared_except "normal" "locked" {
        bind "Ctrl c" { SwitchToMode "normal"; }
    }

    // Esc: soft exit → tmux hub (from scroll sub-mode)
    shared_among "scroll" {
        bind "esc" { SwitchToMode "tmux"; }
    }
}

// Plugins to load in the background when a new session starts
// eg. "file:/path/to/my-plugin.wasm"
// eg. "https://example.com/my-plugin.wasm"
load_plugins {
    zellij:link
    "https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm"
}
