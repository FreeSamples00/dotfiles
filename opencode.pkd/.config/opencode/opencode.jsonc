{
  "$schema": "https://opencode.ai/config.json",
  "model": "synthetic/hf:zai-org/GLM-4.7",
  "share": "disabled",
  // Define permissions for model tooling
  "permission": {
    "*": "ask",
    // read operations
    "read": {
      "*": "allow",
      "*.priv": "deny",
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "pdf_reader": "allow",
    "external_directory": {
      "*": "ask",
      "~/dotfiles": "ask",
    },
    // edit operations
    "write": "deny",
    "edit": "deny",
    "patch": "deny",
    // todolists
    "todoread": "allow",
    "todowrite": "allow",
    // internet
    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    // interaction
    "question": "allow",
    "doom_loop": "ask",
    // commands
    "bash": {
      "*": "ask", // MUST BE FIRST
      "make *": "allow",
      // File Exploration
      "pwd *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      // Git
      "git *": "deny",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      // hard nos
      "pass-cli *": "deny",
      "rm -rf *": "deny",
      // info
      "which *": "allow",
      "brew list": "allow",
      "* --version": "allow",
      "* --help": "allow",
    },
  },
  "agent": {
    "plan": {
      "model": "synthetic/hf:zai-org/GLM-4.7",
      "mode": "primary",
      "permission": {},
    },
    "build": {
      "model": "synthetic/hf:zai-org/GLM-4.7",
      "permission": {
        "edit": "allow",
        "write": "allow",
        "patch": "ask",
      },
    },
  },
  "mcp": {
    "pdf_reader": {
      "type": "local",
      "command": ["uvx", "pdf-reader-mcp"],
      "timeout": 60000,
      "enabled": true,
    },
  },
}
