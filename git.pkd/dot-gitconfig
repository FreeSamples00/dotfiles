# Settings
[core]
	excludesfile = /Users/sccmp/.globalgitignore
  pager = delta
[pull]
	rebase = false
[color]
	ui = auto
	status = auto
	diff = auto
	branch = auto

[merge]
  conflictStyle=zdiff3

[delta]
  side-by-side=false
  line-numbers=true
  navigate=true
  hyperlinks=true
  paging=never
  dark=true
  word-diff=true
  true-color=always
  width=variable
  syntax-theme=Dracula
  minus-style="syntax #660000"
  plus-style="syntax #0e2e1e"
  zero-style="syntax"
  file-style="#cba6f7"
  file-decoration-style=""
  hunk-header-style="#cba6f7 bold"
  hunk-header-decoration-style=""
  inline-hint-style="#cba6f7"
  blame-palette="#6e5d80 #5e4e73 #504267 #43365c #382b52"
  blame-code-style="syntax"
  blame-separator-style="#cba6f7"
  blame-separator-format="{n:^4} │"
