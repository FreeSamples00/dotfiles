# Settings
[core]
	excludesfile = ~/.gitignore
	pager = delta
	editor = nvim
[pull]
	rebase = false
[color]
	ui = auto
	status = auto
	diff = auto
	branch = auto

[merge]
	tool = nvim
	conflictStyle = zdiff3

[mergetool]
	keepBackup = false
	prompt = false

[mergetool "nvim"]
	cmd = "MERGED=\"$MERGED\" nvim -d -c \"wincmd l\" -c \"norm! ]c\" \"$LOCAL\" \"$MERGED\" \"$REMOTE\""

[delta]
	side-by-side=true
	line-numbers=true
	navigate=true
	hyperlinks=true
	paging=auto
	dark=true
	word-diff=true
	true-color=always
	width=variable
	syntax-theme=Dracula
	minus-style="syntax #660000"
	plus-style="syntax #0e2e1e"
	zero-style="syntax"
	file-style="#cba6f7"
	file-decoration-style=""
	hunk-header-style="#cba6f7 bold"
	hunk-header-decoration-style=""
	inline-hint-style="#cba6f7"
	blame-palette="#6e5d80 #5e4e73 #504267 #43365c #382b52"
	blame-code-style="syntax"
	blame-separator-style="#cba6f7"
	blame-separator-format="{n:^4} │"
[init]
	defaultBranch = main
