{
  "$schema": "https://opencode.ai/config.json",
  "model": "synthetic/hf:zai-org/GLM-5.1",
  "small_model": "synthetic/hf:zai-org/GLM-4.7-Flash",
  "default_agent": "plan",
  "share": "disabled",
  "plugin": [
    "@tarquinen/opencode-smart-title",
    "@mohak34/opencode-notifier@latest",
  ],
  "provider": {
    "synthetic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "synthetic",
      "options": {
        "baseURL": "https://api.synthetic.new/openai/v1",
      },
      "models": {
        "hf:zai-org/GLM-5.1": {
          "name": "GLM-5.1",
          "limit": {
            "context": 196608,
            "output": 65536,
          },
          "cost": {
            "input": 1,
            "output": 3,
          },
          "family": "GLM",
          "reasoning": true,
        },
        "hf:openai/gpt-oss-120b": {
          "name": "GPT OSS 120B",
          "limit": {
            "context": 128000,
            "output": 32768,
          },
          "cost": {
            "input": 0.1,
            "output": 0.1,
          },
          "family": "gpt-oss",
          "reasoning": true,
        },
        "hf:zai-org/GLM-4.7-Flash": {
          "name": "GLM-4.7-Flash",
          "limit": {
            "context": 196608,
            "output": 65536,
          },
          "cost": {
            "input": 0.1,
            "output": 0.5,
          },
          "family": "GLM",
          "reasoning": true,
        },
      },
    },
  },
  "permission": {
    "*": "deny",
    "skill": "allow",
    "bash": {
      "*": "ask",
      "make *": "allow",
      "pwd *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      "which *": "allow",
      "brew list": "allow",
      "* --version": "allow",
      "* --help": "allow",
      "just *": "allow",
      "pdftotext *": "allow",
      "pdftoppm *": "allow",
      "pdfinfo *": "allow",
      "tesseract *": "allow",
      "git *": "deny",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "rm -rf *": "deny",
      "pass-cli *": "deny",
    },
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "color": "primary",
      "permission": {
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "codesearch": "allow",
        "question": "allow",
        "doom_loop": "ask",
        "external_directory": {
          "*": "ask",
        },
        "task": {
          "*": "deny",
          "explorer": "allow",
          "librarian": "allow",
          "oracle": "allow",
        },
      },
    },
    "build": {
      "mode": "primary",
      "color": "secondary",
      "permission": {
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "edit": "allow",
        "write": "allow",
        "patch": "ask",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "codesearch": "allow",
        "question": "allow",
        "doom_loop": "ask",
        "external_directory": {
          "*": "ask",
        },
        "task": {
          "*": "allow",
        },
      },
    },
    "explorer": {
      "mode": "subagent",
      "model": "synthetic/hf:zai-org/GLM-4.7-Flash",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "hidden": false,
      "permission": {
        "bash": "deny",
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
      },
    },
    "librarian": {
      "mode": "subagent",
      "model": "synthetic/hf:zai-org/GLM-4.7-Flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "hidden": false,
      "permission": {
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
      },
    },
    "documenter": {
      "mode": "subagent",
      "model": "synthetic/hf:zai-org/GLM-4.7-Flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "hidden": true,
      "permission": {
        "bash": "deny",
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "edit": "allow",
        "write": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
      },
    },
    "fixer": {
      "mode": "subagent",
      "model": "synthetic/hf:zai-org/GLM-4.7-Flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "hidden": true,
      "permission": {
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "edit": "allow",
        "write": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
      },
    },
    "oracle": {
      "mode": "subagent",
      "model": "synthetic/hf:zai-org/GLM-5.1",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "hidden": false,
      "permission": {
        "bash": "deny",
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
      },
    },
    "compaction": {
      "model": "synthetic/hf:openai/gpt-oss-120b",
      "permission": {
        "*": "deny",
      },
    },
  },
}
