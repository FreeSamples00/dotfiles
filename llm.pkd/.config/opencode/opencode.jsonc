{
  "$schema": "https://opencode.ai/config.json",
  "model": "synthetic/syn:large:text",
  "small_model": "synthetic/syn:small:text",
  "default_agent": "plan",
  "share": "disabled",
  "plugin": [
    "@tarquinen/opencode-smart-title",
    "@mohak34/opencode-notifier@latest",
  ],
  "provider": {
    "synthetic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "synthetic",
      "options": {
        "baseURL": "https://api.synthetic.new/openai/v1",
      },
      "models": {
        "syn:large:text": {
          "name": "Max",
          "limit": {
            "context": 524288,
            "output": 65536,
          },
          "cost": {
            "input": 1.4,
            "output": 4.4,
          },
          "family": "GLM",
          "reasoning": true,
        },
        "syn:small:text": {
          "name": "Lite",
          "limit": {
            "context": 196608,
            "output": 65536,
          },
          "cost": {
            "input": 0.1,
            "output": 0.5,
          },
          "family": "GLM",
          "reasoning": true,
        },
        "syn:large:vision": {
          "name": "Vision",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "limit": {
            "context": 262144,
            "output": 65536,
          },
          "cost": {
            "input": 0.95,
            "output": 4.0,
          },
          "family": "Kimi",
          "reasoning": true,
        },
      },
    },
  },
  "permission": {
    "*": "deny",
    "skill": "allow",
    "bash": {
      "*": "ask",
      "nu *": "allow",
      "make *": "allow",
      "pwd *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      "which *": "allow",
      "brew list": "allow",
      "* --version": "allow",
      "* --help": "allow",
      "just *": "allow",
      "pdftotext *": "allow",
      "pdftoppm *": "allow",
      "pdfinfo *": "allow",
      "tesseract *": "allow",
      "git *": "deny",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "rm -rf *": "deny",
      "pass-cli *": "deny",
    },
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "color": "primary",
      "model": "synthetic/syn:large:text",
      "reasoningEffort": "medium",
      "permission": {
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "codesearch": "allow",
        "question": "allow",
        "doom_loop": "ask",
        "external_directory": {
          "*": "ask",
          "/tmp": "allow",
        },
        "task": {
          "*": "deny",
          "explorer": "allow",
          "librarian": "allow",
          "vision": "allow",
          "oracle": "ask",
        },
      },
    },
    "build": {
      "mode": "primary",
      "color": "secondary",
      "model": "synthetic/syn:large:text",
      "reasoningEffort": "low",
      "permission": {
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "edit": "allow",
        "write": "allow",
        "patch": "ask",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "codesearch": "allow",
        "question": "allow",
        "doom_loop": "ask",
        "external_directory": {
          "*": "ask",
          "/tmp": "allow",
        },
        "task": {
          "*": "allow",
          "oracle": "ask",
        },
      },
    },
    "explorer": {
      "mode": "subagent",
      "model": "synthetic/syn:small:text",
      "steps": 12,
      "temperature": 0.2,
      "reasoningEffort": "low",
      "hidden": false,
      "permission": {
        "bash": "deny",
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
      },
    },
    "librarian": {
      "mode": "subagent",
      "model": "synthetic/syn:small:text",
      "steps": 10,
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "hidden": false,
      "permission": {
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
      },
    },
    "documenter": {
      "mode": "subagent",
      "model": "synthetic/syn:small:text",
      "steps": 10,
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "hidden": true,
      "permission": {
        "bash": "deny",
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "edit": "allow",
        "write": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
      },
    },
    "fixer": {
      "mode": "subagent",
      "model": "synthetic/syn:large:text",
      "steps": 25,
      "temperature": 0.2,
      "reasoningEffort": "low",
      "hidden": true,
      "permission": {
        "bash": {
          "*": "deny",
          "just *": "allow",
          "make *": "allow",
          "npm run *": "allow",
          "bun test *": "allow",
          "bun run *": "allow",
          "pytest *": "allow",
          "cargo test *": "allow",
          "cargo check *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "git diff *": "allow",
          "git status": "allow",
        },
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "edit": "allow",
        "write": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
      },
    },
    "compaction": {
      "model": "synthetic/syn:large:text",
      "reasoningEffort": "low",
      "hidden": true,
      "permission": {
        "*": "deny",
      },
    },
    "vision": {
      "mode": "subagent",
      "model": "synthetic/syn:large:vision",
      "steps": 5,
      "temperature": 0.2,
      "reasoningEffort": "low",
      "hidden": false,
      "permission": {
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "file *": "allow",
        },
        "read": {
          "*": "allow",
        },
        "glob": "allow",
        "list": "allow",
        "external_directory": {
          "/tmp": "allow",
        },
      },
    },
    "oracle": {
      "mode": "subagent",
      "model": "synthetic/syn:large:text",
      "steps": 12,
      "temperature": 0.2,
      "reasoningEffort": "high",
      "hidden": false,
      "permission": {
        "bash": "deny",
        "read": {
          "*": "allow",
          "*.priv": "deny",
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "task": {
          "*": "deny",
          "explorer": "allow",
          "librarian": "allow",
          "vision": "allow",
        },
        "external_directory": {
          "*": "ask",
          "/tmp": "allow",
        },
      },
    },
  },
}
