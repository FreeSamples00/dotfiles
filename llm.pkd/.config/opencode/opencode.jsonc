{
  "$schema": "https://opencode.ai/config.json",
  "model": "synthetic/hf:zai-org/GLM-5.1",
  "small_model": "synthetic/hf:zai-org/GLM-4.7-Flash",
  "default_agent": "plan",
  "share": "disabled",
  "plugin": [
    "@tarquinen/opencode-smart-title",
    "@mohak34/opencode-notifier@latest",
  ],
  "provider": {
    "synthetic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "synthetic",
      "options": {
        "baseURL": "https://api.synthetic.new/openai/v1",
      },
      "models": {
        "hf:zai-org/GLM-5.1": {
          "name": "GLM-5.1",
          "limit": {
            "context": 196608,
            "output": 65536,
          },
          "cost": {
            "input": 1,
            "output": 3,
          },
          "family": "GLM",
          "reasoning": true,
        },
        "hf:openai/gpt-oss-120b": {
          "name": "GPT OSS 120B",
          "limit": {
            "context": 128000,
            "output": 32768,
          },
          "cost": {
            "input": 0.1,
            "output": 0.1,
          },
          "family": "gpt-oss",
          "reasoning": true,
        },
        "hf:Qwen/Qwen3-235B-A22B-Thinking-2507": {
          "name": "Qwen3-235B-Thinking",
          "limit": {
            "context": 262144,
            "output": 65536,
          },
          "cost": {
            "input": 0.65,
            "output": 3,
          },
          "family": "Qwen",
          "reasoning": true,
        },
        "hf:zai-org/GLM-4.7-Flash": {
          "name": "GLM-4.7-Flash",
          "limit": {
            "context": 196608,
            "output": 65536,
          },
          "cost": {
            "input": 0.1,
            "output": 0.5,
          },
          "family": "GLM",
          "reasoning": true,
        },
      },
    },
  },
  // Define permissions for model tooling
  "permission": {
    "*": "ask",
    // read operations
    "read": {
      "*": "allow",
      "*.priv": "deny",
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",

    "external_directory": {
      "*": "ask",
      "~/dotfiles": "ask",
    },
    // edit operations
    "write": "deny",
    "edit": "deny",
    "patch": "deny",
    // todolists
    "todoread": "allow",
    "todowrite": "allow",
    // internet
    "websearch": "deny",
    "webfetch": "allow",
    "codesearch": "allow",
    // interaction
    "question": "allow",
    "doom_loop": "ask",
    // sub-agents
    "task": {
      "*": "allow",
    },
    // commands
    "bash": {
      "*": "ask", // MUST BE FIRST
      "make *": "allow",
      // File Exploration
      "pwd *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      // Git
      "git *": "deny",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      // hard nos
      "pass-cli *": "deny",
      "rm -rf *": "deny",
      // info
      "which *": "allow",
      "brew list": "allow",
      "* --version": "allow",
      "* --help": "allow",
      "just *": "allow",
      // PDF tools
      "pdftotext *": "allow",
      "pdftoppm *": "allow",
      "pdfinfo *": "allow",
      "tesseract *": "allow",
    },
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "color": "primary",
      "permission": {
        "task": {
          "*": "deny",
          "explorer": "allow",
          "librarian": "allow",
          "oracle": "allow",
        },
      },
    },
    "build": {
      "mode": "primary",
      "color": "secondary",
      // Alternative model: synthetic/hf:Qwen/Qwen3-Coder-480B-A35B-Instruct
      "permission": {
        "edit": "allow",
        "write": "allow",
        "patch": "ask",
        "task": {
          "*": "allow",
        },
      },
    },
    "compaction": {
      "model": "synthetic/hf:openai/gpt-oss-120b",
      "permission": {
        "*": "deny",
      },
    },
  },
}
