{
  "$schema": "https://opencode.ai/config.json",
  "model": "synthetic/hf:zai-org/GLM-5.1",
  "small_model": "synthetic/hf:openai/gpt-oss-120b",
  "default_agent": "plan",
  "share": "disabled",
  "provider": {
    "synthetic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "synthetic",
      "options": {
        "baseURL": "https://api.synthetic.new/openai/v1",
      },
      "models": {
        "hf:zai-org/GLM-5.1": {
          "name": "GLM-5.1",
          "limit": {
            "context": 196608,
            "output": 65536,
          },
          "cost": {
            "input": 1,
            "output": 3,
          },
          "family": "GLM",
          "reasoning": true,
        },
        "hf:openai/gpt-oss-120b": {
          "name": "GPT OSS 120B",
          "limit": {
            "context": 128000,
            "output": 32768,
          },
          "cost": {
            "input": 0.1,
            "output": 0.1,
          },
          "family": "gpt-oss",
          "reasoning": true,
        },
      },
    },
  },
  // Define permissions for model tooling
  "permission": {
    "*": "ask",
    // read operations
    "read": {
      "*": "allow",
      "*.priv": "deny",
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "pdf_reader": "allow",
    "external_directory": {
      "*": "ask",
      "~/dotfiles": "ask",
    },
    // edit operations
    "write": "deny",
    "edit": "deny",
    "patch": "deny",
    // todolists
    "todoread": "allow",
    "todowrite": "allow",
    // internet
    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    // interaction
    "question": "allow",
    "doom_loop": "ask",
    // sub-agents
    "task": {
      "*": "allow",
      "proofread": "allow",
    },
    // commands
    "bash": {
      "*": "ask", // MUST BE FIRST
      "make *": "allow",
      // File Exploration
      "pwd *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      // Git
      "git *": "deny",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      // hard nos
      "pass-cli *": "deny",
      "rm -rf *": "deny",
      // info
      "which *": "allow",
      "brew list": "allow",
      "* --version": "allow",
      "* --help": "allow",
      "just *": "allow",
    },
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "color": "primary",
      "permission": {},
    },
    "build": {
      "mode": "primary",
      "color": "secondary",
      "permission": {
        "edit": "allow",
        "write": "allow",
        "patch": "ask",
      },
    },
    "explore": {
      "mode": "subagent",
      "model": "synthetic/hf:openai/gpt-oss-120b",
    },
    "general": {
      "model": "synthetic/hf:openai/gpt-oss-120b",
    },
    "scout": {
      "mode": "subagent",
      "model": "synthetic/hf:openai/gpt-oss-120b",
    },
    "text-worker": {
      "model": "synthetic/hf:openai/gpt-oss-120b",
    },
    "proofread": {
      "model": "synthetic/hf:zai-org/GLM-4.7-Flash",
    },
    "compaction": {
      "model": "synthetic/hf:openai/gpt-oss-120b",
    },
  },
  "mcp": {
    "pdf_reader": {
      "type": "local",
      "command": ["uvx", "pdf-reader-mcp"],
      "timeout": 60000,
      "enabled": true,
    },
  },
}
